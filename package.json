{
  "name": "sevdesk-shopify-connector",
  "version": "1.0.0",
  "description": "Payment notification sync between Sevdesk and Shopify",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit/",
    "test:integration": "jest tests/integration/",
    "test:e2e": "jest tests/e2e/ --runInBand --forceExit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "verify": "npm run typecheck && npm run lint && npm test",
    "migrate": "ts-node src/database/migrate.ts"
  },
  "keywords": [
    "sevdesk",
    "shopify",
    "sync",
    "payments"
  ],
  "author": "",
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup/jest.setup.ts",
      "./tests/e2e/setup/jest.setup.ts"
    ],
    "globalSetup": "./tests/setup/globalSetup.ts",
    "globalTeardown": "./tests/setup/globalTeardown.ts"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/nock": "^10.0.3",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^10.0.2",
    "jest": "^29.7.0",
    "nock": "^14.0.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
